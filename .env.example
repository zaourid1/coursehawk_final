# PostgreSQL connection string (Neon, Supabase, Railway, or local)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign session cookies (generate a random string)
SESSION_SECRET=change-me-to-a-random-secret

# OpenAI API key for the AI academic advisor chatbot
OPENAI_API_KEY=sk-your-openai-api-key
